# ─── LLM Provider ──────────────────────────────────────────
# Provider: "openai" | "anthropic" | "gemini" | "ollama" | "azure" | "groq"
DEP_AUDIT_LLM_PROVIDER=openai

# ─── API Keys (usa solo la que corresponda a tu provider) ──
DEP_AUDIT_OPENAI_API_KEY=sk-...
# DEP_AUDIT_ANTHROPIC_API_KEY=sk-ant-...
# DEP_AUDIT_GOOGLE_API_KEY=AIza...
# DEP_AUDIT_GROQ_API_KEY=gsk_...
# DEP_AUDIT_AZURE_API_KEY=...

# ─── Model (opcional, usa default del provider si no se define) ──
# DEP_AUDIT_LLM_MODEL=gpt-4o-mini

# ─── Base URL (opcional, útil para Azure o proxies) ──
# DEP_AUDIT_LLM_BASE_URL=https://api.openai.com/v1

# ─── Temperatura (0.0 = determinista, recomendado para auditoría) ──
# DEP_AUDIT_LLM_TEMPERATURE=0.0

# ─── LangSmith (opcional) ──
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_...
# LANGCHAIN_PROJECT=dep-audit
