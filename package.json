{
  "name": "ai-dependency-auditor",
  "version": "0.0.7",
  "type": "module",
  "description": "AI-powered dependency vulnerability auditor that reduces false positives using LLM analysis",
  "bin": {
    "dep-audit": "./bin/dep-audit.cmd"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup src/cli.ts src/index.ts --out-dir dist --clean --format esm --dts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "security",
    "audit",
    "dependencies",
    "vulnerabilities",
    "llm",
    "ai",
    "npm-audit",
    "cve",
    "osv"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "openai": "^5.0.0",
    "picocolors": "^1.1.1",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  }
}
